datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Notification {
  id          String    @id @default(uuid(7)) @db.Uuid
  userId      String    @db.Uuid
  type        String
  actorUserId String?   @db.Uuid
  readAt      DateTime?
  payload     Json
  createdAt   DateTime  @default(now())

  @@index([userId, id])
}