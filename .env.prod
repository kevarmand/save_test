COMPOSE_PROJECT_NAME=realtime-prod

NODE_ENV=production
SECRETS_DIR=.secrets/prod

GATEWAY_PUBLIC_BIND=0.0.0.0
GATEWAY_PUBLIC_PORT=8443

UPSTREAM_REQUEST_TIMEOUT_MS=3000

WS_AUTH_TIMEOUT_MS=5000
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_PAYLOAD_BYTES=65536

DM_DB_NAME=dm
DM_DB_USER=dm

NOTIFICATIONS_DB_NAME=notifications
NOTIFICATIONS_DB_USER=notifications

USER_SERVICE_HOST=user
USER_SERVICE_PORT=7000

SOCIAL_SERVICE_HOST=social
SOCIAL_SERVICE_PORT=7000