datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Notification {
  id                 String    @id @default(uuid(7)) @db.Uuid
  userId             String    @db.Uuid
  type               String
  actorUserId        String?   @db.Uuid
  conversationUserId String?   @db.Uuid
  messageId          String?   @db.Uuid
  payload            Json
  readAt             DateTime?
  createdAt          DateTime  @default(now())

  @@unique([userId, type, messageId])
  @@index([userId, id])
  @@index([userId, readAt])
  @@index([userId, conversationUserId, messageId])
}